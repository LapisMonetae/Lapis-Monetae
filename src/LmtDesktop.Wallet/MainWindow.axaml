<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LmtDesktop.Wallet.ViewModels"
        x:Class="LmtDesktop.Wallet.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Lapis Monetae Wallet"
        Icon="avares://LmtDesktop.Wallet/Assets/lmt_icon_64.png"
        Width="880" Height="700" MinWidth="680" MinHeight="560"
        Background="#f4f6fa" WindowStartupLocation="CenterScreen">

  <Design.DataContext><vm:MainWindowViewModel /></Design.DataContext>

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Transitions"><Transitions><BrushTransition Property="Background" Duration="0:0:0.15" /><TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" /></Transitions></Setter>
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    </Style>
    <Style Selector="Button:pointerover"><Setter Property="Opacity" Value="0.9" /><Setter Property="RenderTransform" Value="scale(1.02)" /></Style>
    <Style Selector="Button:pressed"><Setter Property="RenderTransform" Value="scale(0.97)" /></Style>
    <Style Selector="Border.card">
      <Setter Property="Transitions"><Transitions><BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" /></Transitions></Setter>
      <Setter Property="BoxShadow" Value="0 1 3 0 #0000001a" />
    </Style>
    <Style Selector="Border.card:pointerover"><Setter Property="BoxShadow" Value="0 4 12 0 #0000001a" /></Style>
    <Style Selector="Border.pill"><Setter Property="Transitions"><Transitions><BrushTransition Property="Background" Duration="0:0:0.3" /></Transitions></Setter></Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="13" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#64748b" /><Setter Property="Padding" Value="16,10" /><Setter Property="Margin" Value="2,0" />
      <Setter Property="Transitions"><Transitions><BrushTransition Property="Foreground" Duration="0:0:0.2" /></Transitions></Setter>
    </Style>
    <Style Selector="TabItem:pointerover"><Setter Property="Foreground" Value="#2563eb" /></Style>
    <Style Selector="TabItem:selected"><Setter Property="Foreground" Value="#2563eb" /></Style>
    <Style Selector="TextBox"><Setter Property="Transitions"><Transitions><BrushTransition Property="BorderBrush" Duration="0:0:0.15" /></Transitions></Setter></Style>
    <Style Selector="TextBox:focus"><Setter Property="BorderBrush" Value="#2563eb" /></Style>
    <!-- Overlay backdrop -->
    <Style Selector="Border.overlay"><Setter Property="Background" Value="#80000000" /></Style>
    <!-- Field labels -->
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,2,0,4" />
    </Style>
    <!-- Section titles -->
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <!-- Action button base -->
    <Style Selector="Button.actionBtn">
      <Setter Property="Background" Value="#f1f5f9" />
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="BorderBrush" Value="#e2e8f0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <!-- DataGrid alternating rows -->
    <Style Selector="DataGridRow:nth-child(even)">
      <Setter Property="Background" Value="#f8fafc" />
    </Style>
    <Style Selector="DataGridRow:pointerover">
      <Setter Property="Background" Value="#eff6ff" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="#f1f5f9" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
  </Window.Styles>

  <Panel>
  <Grid RowDefinitions="Auto,2,*,Auto">

    <!-- HEADER -->
    <Border Grid.Row="0" Background="White" Padding="16,10" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,8,Auto">
        <Image Grid.Column="0" Source="avares://LmtDesktop.Wallet/Assets/lmt_icon_64.png" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Lapis Monetae" FontSize="17" FontWeight="Bold" Foreground="#1e293b" />
          <TextBlock Text=" Wallet" FontSize="17" Foreground="#64748b" />
        </StackPanel>
        <!-- Backup warning pill -->
        <Border Grid.Column="3" IsVisible="{Binding BackupPillVisible}" Background="#fbbf24" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
          <TextBlock Text="BACKUP" Foreground="#92400e" FontSize="10" FontWeight="Bold" />
        </Border>
        <Border Grid.Column="5" Classes="pill" Background="{Binding PillBg}" CornerRadius="12" Padding="12,5" VerticalAlignment="Center">
          <TextBlock Text="{Binding PillText}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <!-- Gradient -->
    <Border Grid.Row="1"><Border.Background><LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%"><GradientStop Color="#2563eb" Offset="0" /><GradientStop Color="#7c3aed" Offset="0.5" /><GradientStop Color="#f59e0b" Offset="1" /></LinearGradientBrush></Border.Background></Border>

    <!-- Busy overlay -->
    <Border Grid.Row="2" IsVisible="{Binding IsBusy}" Background="#40000000" ZIndex="50">
      <Border Background="White" CornerRadius="12" Padding="28,20" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
        <TextBlock Text="{Binding BusyText}" Foreground="#1e293b" FontSize="14" FontWeight="SemiBold" />
      </Border>
    </Border>

    <!-- CONTENT -->
    <Grid Grid.Row="2">

      <!-- SETUP -->
      <Border IsVisible="{Binding ShowSetup}" Background="#f4f6fa">
        <ScrollViewer><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Width="440" Margin="0,32">
          <Image Source="avares://LmtDesktop.Wallet/Assets/lmt_logo.png" Width="100" Height="100" HorizontalAlignment="Center" />
          <TextBlock Text="Welcome to Lapis Monetae" FontSize="22" FontWeight="Bold" Foreground="#1e293b" HorizontalAlignment="Center" />
          <TextBlock Text="Select your lmt-cli binary to get started." FontSize="13" Foreground="#64748b" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
          <Border IsVisible="{Binding SetupError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#fef2f2" CornerRadius="8" Padding="12,8" BorderBrush="#fecaca" BorderThickness="1">
            <TextBlock Text="{Binding SetupError}" Foreground="#dc2626" FontSize="12" TextWrapping="Wrap" /></Border>
          <Border IsVisible="{Binding SetupStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#f0fdf4" CornerRadius="8" Padding="12,8" BorderBrush="#bbf7d0" BorderThickness="1">
            <TextBlock Text="{Binding SetupStatus}" Foreground="#166534" FontSize="12" TextWrapping="Wrap" /></Border>
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <TextBlock Text="CLI Binary Path" Foreground="#475569" FontSize="13" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto"><TextBox Text="{Binding CliPath}" Watermark="C:\path\to\lmt-cli.exe" CornerRadius="8" Padding="10,8" FontSize="13" />
              <Button Grid.Column="1" Content="Browse..." Click="BrowseCliPath_Click" Margin="8,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="14,8" BorderBrush="#e2e8f0" BorderThickness="1" FontWeight="SemiBold" /></Grid>
            <TextBlock Text="Network" Foreground="#475569" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
            <ComboBox SelectedItem="{Binding SelectedNetwork}" CornerRadius="8" HorizontalAlignment="Stretch"><ComboBoxItem Content="mainnet" /><ComboBoxItem Content="testnet-10" /><ComboBoxItem Content="testnet-11" /></ComboBox>
          </StackPanel></Border>
          <Button Content="Continue" Command="{Binding ValidateAndContinueCommand}" IsEnabled="{Binding !SetupBusy}" HorizontalAlignment="Stretch" Height="46" FontSize="15" FontWeight="SemiBold" Background="#2563eb" Foreground="White" CornerRadius="10" HorizontalContentAlignment="Center" />
          <Border Background="#eff6ff" CornerRadius="8" Padding="12,8" BorderBrush="#bfdbfe" BorderThickness="1"><TextBlock Foreground="#1e40af" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"><Run>Haven't compiled yet? Run: </Run><Run FontWeight="SemiBold">cargo build --release -p lmt-cli</Run></TextBlock></Border>
        </StackPanel></ScrollViewer>
      </Border>

      <!-- WIZARD -->
      <Border IsVisible="{Binding ShowFirstRun}" Background="#f4f6fa">
        <ScrollViewer><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Width="420" Margin="0,32">
          <Image Source="avares://LmtDesktop.Wallet/Assets/lmt_logo.png" Width="100" Height="100" HorizontalAlignment="Center" />
          <TextBlock Text="Lapis Monetae Wallet" FontSize="22" FontWeight="Bold" Foreground="#1e293b" HorizontalAlignment="Center" />
          <!-- Error -->
          <Border IsVisible="{Binding WizardError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#fef2f2" CornerRadius="8" Padding="12,8" BorderBrush="#fecaca" BorderThickness="1">
            <TextBlock Text="{Binding WizardError}" Foreground="#dc2626" FontSize="12" TextWrapping="Wrap" /></Border>

          <!-- Step 0: Welcome -->
          <StackPanel IsVisible="{Binding IsStep0}" Spacing="10" Margin="0,12,0,0">
            <Button Command="{Binding StartCreateWalletCommand}" HorizontalAlignment="Stretch" Height="52" FontSize="15" FontWeight="SemiBold" Background="#2563eb" Foreground="White" CornerRadius="10" HorizontalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{StaticResource IconNew}" Width="16" Height="16" Foreground="White" />
                <TextBlock Text="Create New Wallet" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" />
              </StackPanel>
            </Button>
            <Button Command="{Binding StartImportWalletCommand}" HorizontalAlignment="Stretch" Height="52" FontSize="15" Background="White" Foreground="#1e293b" CornerRadius="10" BorderBrush="#e2e8f0" BorderThickness="1" HorizontalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{StaticResource IconImport}" Width="16" Height="16" Foreground="#64748b" />
                <TextBlock Text="I Already Have a Wallet" VerticalAlignment="Center" FontSize="15" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Step 4: Seed Backup Checklist (create only, before name/pass) -->
          <StackPanel IsVisible="{Binding IsStep4}" Spacing="10" Margin="0,8,0,0">
            <TextBlock Text="Before You Begin" FontSize="16" FontWeight="Bold" Foreground="#1e293b" />
            <Border Background="#fffbeb" CornerRadius="8" Padding="14,10" BorderBrush="#fde68a" BorderThickness="1">
              <TextBlock Text="Your wallet will generate a secret seed phrase. This is the ONLY way to recover your funds. Please confirm:" Foreground="#92400e" FontSize="13" TextWrapping="Wrap" />
            </Border>
            <CheckBox IsChecked="{Binding CheckSafePlace}" Foreground="#1e293b" FontSize="13" Margin="0,4,0,0"><TextBlock TextWrapping="Wrap">I have a safe place to write down my seed phrase</TextBlock></CheckBox>
            <CheckBox IsChecked="{Binding CheckShownOnce}" Foreground="#1e293b" FontSize="13"><TextBlock TextWrapping="Wrap">I understand the seed is shown only once during creation</TextBlock></CheckBox>
            <CheckBox IsChecked="{Binding CheckNoScreenshot}" Foreground="#1e293b" FontSize="13"><TextBlock TextWrapping="Wrap">I will NOT screenshot or store the seed digitally</TextBlock></CheckBox>
            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
              <Button Grid.Column="0" Content="Back" Command="{Binding WizardBackCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" Margin="0,0,4,0" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" />
              <Button Grid.Column="1" Content="I'm Ready" Command="{Binding ChecklistProceedCommand}" IsEnabled="{Binding AllChecksComplete}" Background="#2563eb" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" Margin="4,0,0,0" HorizontalContentAlignment="Center" FontWeight="SemiBold" />
            </Grid>
          </StackPanel>

          <!-- Step 1: Name + Password -->
          <StackPanel IsVisible="{Binding IsStep1}" Spacing="10" Margin="0,8,0,0">
            <TextBlock Text="Wallet Name" FontSize="13" FontWeight="SemiBold" Foreground="#475569" />
            <TextBox Watermark="my-wallet" Text="{Binding NewWalletName}" MaxLength="64" CornerRadius="8" Padding="10,8" FontSize="14" />
            <StackPanel IsVisible="{Binding IsImportFlow}" Spacing="6">
              <TextBlock Text="Seed Phrase (12 or 24 words)" FontSize="13" FontWeight="SemiBold" Foreground="#475569" />
              <TextBox Watermark="word1 word2 word3 ..." Text="{Binding ImportMnemonic}" MaxLength="600" CornerRadius="8" Padding="10,8" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" Height="72" />
            </StackPanel>
            <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,6,0,0" />
            <TextBox Watermark="Minimum 8 characters" Text="{Binding NewPassword}" PasswordChar="*" MaxLength="128" CornerRadius="8" Padding="10,8" FontSize="14" />
            <TextBox Watermark="Confirm password" Text="{Binding ConfirmPassword}" PasswordChar="*" MaxLength="128" CornerRadius="8" Padding="10,8" FontSize="14" />
            <Border Background="#fffbeb" CornerRadius="8" Padding="12,8" BorderBrush="#fde68a" BorderThickness="1">
              <TextBlock Text="This password encrypts your wallet. No recovery if forgotten." Foreground="#92400e" FontSize="12" TextWrapping="Wrap" /></Border>
            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
              <Button Grid.Column="0" Content="Back" Command="{Binding WizardBackCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" Margin="0,0,4,0" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" />
              <Button Grid.Column="1" Content="Continue" Command="{Binding WizardNextCommand}" IsEnabled="{Binding !WizardBusy}" Background="#2563eb" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" Margin="4,0,0,0" HorizontalContentAlignment="Center" FontWeight="SemiBold" />
            </Grid>
          </StackPanel>

          <!-- Step 2: Mnemonic Display -->
          <StackPanel IsVisible="{Binding IsStep2}" Spacing="10" Margin="0,8,0,0">
            <TextBlock Text="Your Seed Phrase" FontSize="16" FontWeight="Bold" Foreground="#1e293b" />
            <Border Background="#fffbeb" CornerRadius="8" Padding="12,8" BorderBrush="#fde68a" BorderThickness="1">
              <TextBlock Text="Write these words on paper NOW. They will NOT be shown again." Foreground="#92400e" FontSize="12" TextWrapping="Wrap" /></Border>
            <Border Background="White" CornerRadius="10" Padding="16,14" BorderBrush="#e2e8f0" BorderThickness="1">
              <TextBlock Text="{Binding MnemonicDisplay}" Foreground="#1e293b" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="30" /></Border>
            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
              <Button Grid.Column="0" Content="Back" Command="{Binding WizardBackCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" Margin="0,0,4,0" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" />
              <Button Grid.Column="1" Content="I Wrote It Down" Command="{Binding WizardNextCommand}" Background="#16a34a" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" Margin="4,0,0,0" HorizontalContentAlignment="Center" FontWeight="SemiBold" />
            </Grid>
          </StackPanel>

          <!-- Step 3: Verify -->
          <StackPanel IsVisible="{Binding IsStep3}" Spacing="10" Margin="0,8,0,0">
            <TextBlock Text="Verify Your Backup" FontSize="16" FontWeight="Bold" Foreground="#1e293b" />
            <TextBlock Text="Enter these words from your seed phrase:" FontSize="13" Foreground="#64748b" />
            <Grid ColumnDefinitions="90,*"><TextBlock Text="{Binding VerifyLabel1}" VerticalAlignment="Center" Foreground="#475569" FontSize="13" FontWeight="SemiBold" /><TextBox Grid.Column="1" Text="{Binding VerifyWord1}" Watermark="Enter word..." CornerRadius="8" Padding="10,8" /></Grid>
            <Grid ColumnDefinitions="90,*"><TextBlock Text="{Binding VerifyLabel2}" VerticalAlignment="Center" Foreground="#475569" FontSize="13" FontWeight="SemiBold" /><TextBox Grid.Column="1" Text="{Binding VerifyWord2}" Watermark="Enter word..." CornerRadius="8" Padding="10,8" /></Grid>
            <Grid ColumnDefinitions="90,*"><TextBlock Text="{Binding VerifyLabel3}" VerticalAlignment="Center" Foreground="#475569" FontSize="13" FontWeight="SemiBold" /><TextBox Grid.Column="1" Text="{Binding VerifyWord3}" Watermark="Enter word..." CornerRadius="8" Padding="10,8" /></Grid>
            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
              <Button Grid.Column="0" Content="Back" Command="{Binding WizardBackCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" Margin="0,0,4,0" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" />
              <Button Grid.Column="1" Content="Verify and Open" Command="{Binding WizardNextCommand}" Background="#2563eb" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" Margin="4,0,0,0" HorizontalContentAlignment="Center" FontWeight="SemiBold" />
            </Grid>
          </StackPanel>
        </StackPanel></ScrollViewer>
      </Border>

      <!-- MAIN TABS -->
      <TabControl IsVisible="{Binding ShowMain}" Background="#f4f6fa" Padding="0" Margin="0,2,0,0">

        <!-- Actions -->
        <TabItem Header="  Actions  "><ScrollViewer Padding="16"><StackPanel Spacing="14">

          <!-- Wallet Operations -->
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconWallet}" Width="15" Height="15" Foreground="#2563eb" />
              <TextBlock Classes="sectionTitle" Text="Wallet" Foreground="#2563eb" />
            </StackPanel>
            <Grid ColumnDefinitions="*,8,*,8,*,8,*">
              <Button Grid.Column="0" Command="{Binding OpenWalletCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconOpen}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Open" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding LaunchInteractiveCommand}" CommandParameter="wallet create" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconNew}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Create" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="4" Command="{Binding LaunchInteractiveCommand}" CommandParameter="wallet import" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconImport}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Import" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="6" Command="{Binding LockWalletCommand}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconLock}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Lock" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel></Border>

          <!-- Accounts -->
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconAddress}" Width="15" Height="15" Foreground="#0891b2" />
              <TextBlock Classes="sectionTitle" Text="Accounts" Foreground="#0891b2" />
            </StackPanel>
            <Grid ColumnDefinitions="*,8,*,8,*">
              <Button Grid.Column="0" Command="{Binding RefreshBalancesCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconBalance}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Balances" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding GetAddressCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconAddress}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Address" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="4" Command="{Binding NewAddressCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconNew}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="New Address" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel></Border>

          <!-- Transactions -->
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconSend}" Width="15" Height="15" Foreground="#d97706" />
              <TextBlock Classes="sectionTitle" Text="Transactions" Foreground="#d97706" />
            </StackPanel>
            <Grid ColumnDefinitions="*,8,*,8,*,8,*">
              <Button Grid.Column="0" Command="{Binding OpenSendDialogCommand}" IsEnabled="{Binding IsNotBusy}" Background="#d97706" Foreground="White" CornerRadius="8" Padding="14,8" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconSend}" Width="14" Height="14" Foreground="White" />
                  <TextBlock Text="Send" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding OpenTransferDialogCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconTransfer}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Transfer" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="4" Command="{Binding RefreshTransactionsCommand}" IsEnabled="{Binding IsNotBusy}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconHistory}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Tx History" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="6" Command="{Binding OpenContactsDialogCommand}" Classes="actionBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconContacts}" Width="14" Height="14" Foreground="#475569" />
                  <TextBlock Text="Contacts" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel></Border>

        </StackPanel></ScrollViewer></TabItem>

        <!-- Output -->
        <TabItem Header="  Output  ">
          <Grid RowDefinitions="Auto,*" Margin="12">
            <Border Grid.Row="0" Background="White" CornerRadius="8,8,0,0" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,1,0">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource IconTerminal}" Width="14" Height="14" Foreground="#64748b" />
                  <TextBlock Text="CLI Output" Foreground="#475569" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding OutputLines.Count, StringFormat='{}{0} lines'}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ListBox Grid.Row="1" ItemsSource="{Binding OutputLines}" Background="#1e1e2e"
                     BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="0,0,8,8"
                     FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#a6e3a1" Padding="8,4" />
          </Grid>
        </TabItem>

        <!-- History -->
        <TabItem Header="  History  "><Border Padding="12" Background="#f4f6fa">
          <Border Background="White" CornerRadius="8" BorderBrush="#e2e8f0" BorderThickness="1" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding HistoryEntries}" IsReadOnly="True" Background="White" BorderThickness="0" GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowBackground="White">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="80" />
                <DataGridTextColumn Header="" Binding="{Binding StatusSymbol}" Width="30" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="90" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Border></TabItem>

        <!-- Transactions -->
        <TabItem Header="  Transactions  "><Border Padding="12" Background="#f4f6fa">
          <Border Background="White" CornerRadius="8" BorderBrush="#e2e8f0" BorderThickness="1" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Transactions}" IsReadOnly="True" Background="White" BorderThickness="0" GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowBackground="White">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding When}" Width="80" />
                <DataGridTextColumn Header="TxID" Binding="{Binding TxId}" Width="100" />
                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="50" />
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Border></TabItem>

        <!-- Node -->
        <TabItem Header="  Node  "><ScrollViewer Padding="16"><StackPanel Spacing="12">
          <!-- Connection Card -->
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconNode}" Width="15" Height="15" Foreground="#2563eb" />
              <TextBlock Classes="sectionTitle" Text="Connection" Foreground="#2563eb" />
            </StackPanel>
            <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
              <StackPanel Grid.Column="0">
                <TextBlock Text="STATUS" Foreground="#94a3b8" FontSize="10" FontWeight="Bold" />
                <TextBlock Text="{Binding NodeStatusText}" Foreground="#1e293b" FontSize="16" FontWeight="Bold" Margin="0,2,0,0" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="LATENCY" Foreground="#94a3b8" FontSize="10" FontWeight="Bold" />
                <TextBlock Text="{Binding Latency}" Foreground="#1e293b" FontSize="16" FontWeight="SemiBold" Margin="0,2,0,0" />
              </StackPanel>
            </Grid>
          </StackPanel></Border>

          <!-- DAG + Network side by side -->
          <Grid ColumnDefinitions="*,12,*">
            <Border Grid.Column="0" Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconChart}" Width="15" Height="15" Foreground="#0891b2" />
                <TextBlock Classes="sectionTitle" Text="DAG" Foreground="#0891b2" />
              </StackPanel>
              <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="DAA Score" Foreground="#64748b" FontSize="12" Margin="0,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DaaScore}" Foreground="#1e293b" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tip Hash" Foreground="#64748b" FontSize="12" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TipHash}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="11" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Difficulty" Foreground="#64748b" FontSize="12" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Difficulty}" Foreground="#1e293b" FontWeight="SemiBold" Margin="0,4" />
              </Grid>
            </StackPanel></Border>
            <Border Grid.Column="2" Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconNode}" Width="15" Height="15" Foreground="#d97706" />
                <TextBlock Classes="sectionTitle" Text="Network" Foreground="#d97706" />
              </StackPanel>
              <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Peers" Foreground="#64748b" FontSize="12" Margin="0,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Peers}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="18" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Network" Foreground="#64748b" FontSize="12" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NetworkName}" Foreground="#1e293b" FontWeight="SemiBold" Margin="0,4" />
              </Grid>
            </StackPanel></Border>
          </Grid>
        </StackPanel></ScrollViewer></TabItem>

        <!-- Config -->
        <TabItem Header="  Config  "><ScrollViewer Padding="16"><StackPanel Spacing="12">
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconConfig}" Width="15" Height="15" Foreground="#2563eb" />
              <TextBlock Classes="sectionTitle" Text="CLI Configuration" Foreground="#2563eb" />
            </StackPanel>
            <TextBlock Classes="fieldLabel" Text="CLI Binary Path" />
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBox Text="{Binding CliPath}" Watermark="/path/to/lmt-cli" CornerRadius="8" Padding="10,8" FontSize="13" />
              <Button Grid.Column="1" Content="Browse..." Click="BrowseCliPath_Click" Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,8" BorderBrush="#e2e8f0" BorderThickness="1" />
              <Button Grid.Column="2" Content="Save" Command="{Binding SaveCliPathCommand}" Margin="6,0,0,0" Background="#2563eb" Foreground="White" CornerRadius="8" Padding="16,8" FontWeight="SemiBold" />
            </Grid>
            <TextBlock Classes="fieldLabel" Text="Network" Margin="0,8,0,4" />
            <ComboBox SelectedItem="{Binding SelectedNetwork}" CornerRadius="8" HorizontalAlignment="Stretch"><ComboBoxItem Content="mainnet" /><ComboBoxItem Content="testnet-10" /><ComboBoxItem Content="testnet-11" /></ComboBox>
          </StackPanel></Border>
          <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1"><StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{StaticResource IconLock}" Width="15" Height="15" Foreground="#d97706" />
              <TextBlock Classes="sectionTitle" Text="Session Security" Foreground="#d97706" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Lock after" VerticalAlignment="Center" Foreground="#475569" />
              <NumericUpDown Value="{Binding SessionTimeoutMinutes}" Minimum="0" Maximum="60" Increment="5" Width="100" />
              <TextBlock Text="minutes (0 = off)" VerticalAlignment="Center" Foreground="#64748b" FontSize="12" />
            </StackPanel>
            <CheckBox IsChecked="{Binding AutoLockOnTimeout}" Content="Auto-lock (no confirmation prompt)" Foreground="#475569" />
            <Button Content="Save Session Settings" Command="{Binding SaveSessionSettingsCommand}" Background="#2563eb" Foreground="White" CornerRadius="8" Padding="16,8" FontWeight="SemiBold" HorizontalAlignment="Left" />
          </StackPanel></Border>
        </StackPanel></ScrollViewer></TabItem>

      </TabControl>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3" Background="White" Padding="12,6" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding StatusText}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" /><TextBlock Grid.Column="1" Text="{Binding NodeStatusText}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" /></Grid>
    </Border>

  </Grid>

  <!-- OVERLAY DIALOGS -->

  <!-- Send Dialog -->
  <Border Classes="overlay" IsVisible="{Binding ShowSendDialog}" ZIndex="100">
    <Border Background="White" CornerRadius="12" Padding="24" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Data="{StaticResource IconSend}" Width="18" Height="18" Foreground="#d97706" />
          <TextBlock Text="Send LMT" FontSize="18" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
        </StackPanel>
        <Border IsVisible="{Binding SendError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#fef2f2" CornerRadius="6" Padding="10,6" BorderBrush="#fecaca" BorderThickness="1">
          <TextBlock Text="{Binding SendError}" Foreground="#dc2626" FontSize="12" TextWrapping="Wrap" /></Border>

        <!-- Not showing confirm -->
        <StackPanel IsVisible="{Binding !ShowSendConfirm}" Spacing="10">
          <TextBlock Classes="fieldLabel" Text="Contact (optional)" />
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding Contacts}" SelectedIndex="{Binding SelectedContactIndex}" DisplayMemberBinding="{Binding Name}" HorizontalAlignment="Stretch" CornerRadius="8" />
            <Button Grid.Column="1" Content="Use" Command="{Binding FillFromContactCommand}" Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,6" FontSize="12" BorderBrush="#e2e8f0" BorderThickness="1" />
          </Grid>
          <TextBlock Classes="fieldLabel" Text="Recipient Address" />
          <TextBox Text="{Binding SendAddress}" Watermark="lmt:..." CornerRadius="8" Padding="10,8" FontSize="13" />
          <Grid ColumnDefinitions="*,12,*">
            <StackPanel Grid.Column="0">
              <TextBlock Classes="fieldLabel" Text="Amount (LMT)" />
              <TextBox Text="{Binding SendAmount}" Watermark="0.00" CornerRadius="8" Padding="10,8" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Classes="fieldLabel" Text="Fee (optional)" />
              <TextBox Text="{Binding SendFee}" Watermark="0" CornerRadius="8" Padding="10,8" />
            </StackPanel>
          </Grid>
          <Grid ColumnDefinitions="*,8,*" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseSendDialogCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" Padding="0,10" />
            <Button Grid.Column="2" Content="Review Send" Command="{Binding SubmitSendCommand}" Background="#d97706" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="SemiBold" Padding="0,10" />
          </Grid>
        </StackPanel>

        <!-- Confirmation -->
        <StackPanel IsVisible="{Binding ShowSendConfirm}" Spacing="8">
          <TextBlock Text="Confirm Transaction" FontSize="15" FontWeight="SemiBold" Foreground="#1e293b" />
          <Border Background="#f8fafc" CornerRadius="8" Padding="14,10" BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Network" Foreground="#64748b" FontSize="12" Margin="0,3" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConfirmNetwork}" Foreground="#1e293b" FontWeight="SemiBold" Margin="0,3" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount" Foreground="#64748b" FontSize="12" Margin="0,3" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConfirmAmount}" Foreground="#1e293b" FontWeight="SemiBold" Margin="0,3" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Fee" Foreground="#64748b" FontSize="12" Margin="0,3" />
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConfirmFee}" Foreground="#1e293b" Margin="0,3" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Total" Foreground="#64748b" FontSize="12" FontWeight="Bold" Margin="0,3" />
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ConfirmTotal}" Foreground="#dc2626" FontWeight="Bold" FontSize="14" Margin="0,3" />
            </Grid>
          </Border>
          <TextBlock Text="To address:" Foreground="#64748b" FontSize="12" Margin="0,4,0,0" />
          <Border Background="#f1f5f9" CornerRadius="6" Padding="10,8"><TextBlock Text="{Binding ConfirmAddress}" Foreground="#1e293b" FontSize="11" FontFamily="Consolas,monospace" TextWrapping="Wrap" /></Border>
          <Border Background="#fffbeb" CornerRadius="6" Padding="10,6" BorderBrush="#fde68a" BorderThickness="1">
            <TextBlock Text="This will open a terminal for your wallet password." Foreground="#92400e" FontSize="11" TextWrapping="Wrap" /></Border>
          <Grid ColumnDefinitions="*,8,*" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseSendDialogCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" Padding="0,10" />
            <Button Grid.Column="2" Command="{Binding ConfirmSendCommand}" Background="#16a34a" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="SemiBold" Padding="0,10">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IconSend}" Width="14" Height="14" Foreground="White" />
                <TextBlock Text="Send Now" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>

  <!-- Transfer Dialog -->
  <Border Classes="overlay" IsVisible="{Binding ShowTransferDialog}" ZIndex="100">
    <Border Background="White" CornerRadius="12" Padding="24" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Data="{StaticResource IconTransfer}" Width="18" Height="18" Foreground="#2563eb" />
          <TextBlock Text="Transfer Between Accounts" FontSize="18" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
        </StackPanel>
        <Border IsVisible="{Binding TransferError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#fef2f2" CornerRadius="6" Padding="10,6" BorderBrush="#fecaca" BorderThickness="1">
          <TextBlock Text="{Binding TransferError}" Foreground="#dc2626" FontSize="12" TextWrapping="Wrap" /></Border>
        <TextBlock Classes="fieldLabel" Text="Target Account" />
        <ComboBox ItemsSource="{Binding AccountSuggestions}" SelectedItem="{Binding TransferAccount}" IsEditable="True" HorizontalAlignment="Stretch" CornerRadius="8" />
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="fieldLabel" Text="Amount (LMT)" />
            <TextBox Text="{Binding TransferAmount}" Watermark="0.00" CornerRadius="8" Padding="10,8" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="fieldLabel" Text="Fee (optional)" />
            <TextBox Text="{Binding TransferFee}" Watermark="0" CornerRadius="8" Padding="10,8" />
          </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="*,8,*" Margin="0,8,0,0">
          <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseTransferDialogCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" Padding="0,10" />
          <Button Grid.Column="2" Content="Transfer" Command="{Binding SubmitTransferCommand}" Background="#2563eb" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="SemiBold" Padding="0,10" />
        </Grid>
      </StackPanel>
    </Border>
  </Border>

  <!-- Contacts Dialog -->
  <Border Classes="overlay" IsVisible="{Binding ShowContactsDialog}" ZIndex="100">
    <Border Background="White" CornerRadius="12" Padding="24" Width="520" MaxHeight="520" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Data="{StaticResource IconContacts}" Width="18" Height="18" Foreground="#2563eb" />
          <TextBlock Text="Contacts" FontSize="18" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
        </StackPanel>
        <Border IsVisible="{Binding ContactError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="#fef2f2" CornerRadius="6" Padding="10,6" BorderBrush="#fecaca" BorderThickness="1">
          <TextBlock Text="{Binding ContactError}" Foreground="#dc2626" FontSize="12" TextWrapping="Wrap" /></Border>
        <ListBox ItemsSource="{Binding Contacts}" SelectedIndex="{Binding SelectedContactEditIndex}" Height="120" Background="#f8fafc" BorderBrush="#e2e8f0" CornerRadius="6">
          <ListBox.ItemTemplate><DataTemplate><TextBlock><Run Text="{Binding Name}" FontWeight="SemiBold" /> <Run Text=" -- " Foreground="#94a3b8" /> <Run Text="{Binding Address}" Foreground="#64748b" FontSize="11" /></TextBlock></DataTemplate></ListBox.ItemTemplate>
        </ListBox>
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="fieldLabel" Text="Name" />
            <TextBox Text="{Binding ContactName}" Watermark="Alice" CornerRadius="8" Padding="8,6" MaxLength="48" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="fieldLabel" Text="Note" />
            <TextBox Text="{Binding ContactNote}" Watermark="Optional" CornerRadius="8" Padding="8,6" MaxLength="140" />
          </StackPanel>
        </Grid>
        <TextBlock Classes="fieldLabel" Text="Address" />
        <TextBox Text="{Binding ContactAddress}" Watermark="lmt:..." CornerRadius="8" Padding="10,8" FontSize="12" MaxLength="120" />
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Command="{Binding AddContactCommand}" Background="#16a34a" Foreground="White" CornerRadius="8" Padding="14,7" FontWeight="SemiBold">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <PathIcon Data="{StaticResource IconNew}" Width="12" Height="12" Foreground="White" />
              <TextBlock Text="Add" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Content="Remove" Command="{Binding RemoveContactCommand}" Background="White" Foreground="#dc2626" CornerRadius="8" Padding="14,7" BorderBrush="#fecaca" BorderThickness="1" />
          <Button Content="Close" Command="{Binding CloseContactsDialogCommand}" Background="White" Foreground="#64748b" CornerRadius="8" Padding="14,7" BorderBrush="#e2e8f0" BorderThickness="1" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>

  <!-- Error Action Dialog -->
  <Border Classes="overlay" IsVisible="{Binding ShowErrorDialog}" ZIndex="100">
    <Border Background="White" CornerRadius="12" Padding="24" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
      <StackPanel Spacing="14">
        <TextBlock Text="Action Needed" FontSize="16" FontWeight="Bold" Foreground="#dc2626" />
        <TextBlock Text="{Binding ErrorDialogMessage}" Foreground="#1e293b" FontSize="14" TextWrapping="Wrap" />
        <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
          <Button Grid.Column="0" Content="Dismiss" Command="{Binding DismissErrorDialogCommand}" Background="White" Foreground="#64748b" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#e2e8f0" BorderThickness="1" Padding="0,10" />
          <Button Grid.Column="2" Content="{Binding ErrorDialogAction}" Command="{Binding ExecuteErrorActionCommand}" Background="#2563eb" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="SemiBold" Padding="0,10" />
        </Grid>
      </StackPanel>
    </Border>
  </Border>

  <!-- Toast Notification -->
  <Border IsVisible="{Binding ToastVisible}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16,12" ZIndex="200"
          Background="{Binding ActiveToast.Background}" CornerRadius="8" Padding="0" Width="360" BoxShadow="0 4 16 0 #0000001a">
    <Border.Transitions><Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.25" /></Transitions></Border.Transitions>
    <Grid ColumnDefinitions="4,Auto,*">
      <Border Grid.Column="0" Background="{Binding ActiveToast.AccentColor}" CornerRadius="8,0,0,8" />
      <TextBlock Grid.Column="1" Text="{Binding ActiveToast.Icon}" Foreground="{Binding ActiveToast.AccentColor}" FontSize="16" VerticalAlignment="Center" Margin="12,10,8,10" />
      <TextBlock Grid.Column="2" Text="{Binding ActiveToast.Text}" Foreground="{Binding ActiveToast.Foreground}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,10,12,10" />
    </Grid>
  </Border>

  </Panel>
</Window>
