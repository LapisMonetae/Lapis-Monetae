<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LmtDesktop.Miner.ViewModels"
        x:Class="LmtDesktop.Miner.MainWindow"
        x:DataType="vm:MinerMainViewModel"
        Title="LMT Miner Control Center"
        Icon="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png"
        Width="920" Height="740" MinWidth="720" MinHeight="640"
        Background="#f4f6fa" WindowStartupLocation="CenterScreen">

  <Design.DataContext><vm:MinerMainViewModel /></Design.DataContext>

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
        </Transitions>
      </Setter>
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Opacity" Value="0.9" />
      <Setter Property="RenderTransform" Value="scale(1.02)" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Transitions">
        <Transitions>
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
      <Setter Property="BoxShadow" Value="0 1 3 0 #0000001a" />
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="BoxShadow" Value="0 4 12 0 #0000001a" />
    </Style>
    <Style Selector="Border.pill">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.3" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Modern TabItem styling -->
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#64748b" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="2,0" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TabItem:pointerover">
      <Setter Property="Foreground" Value="#2563eb" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="#2563eb" />
    </Style>

    <!-- Tab content fade-in -->
    <Style Selector="TabItem:selected > ContentPresenter">
      <Style.Animations>
        <Animation Duration="0:0:0.25" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="8" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#2563eb" />
    </Style>

    <!-- Label style for form fields -->
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,2,0,4" />
    </Style>

    <!-- Section header -->
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
  </Window.Styles>

  <Panel>
  <Grid RowDefinitions="Auto,2,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="White" Padding="16,10" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <Image Grid.Column="0" Source="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png"
               Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="LMT" FontSize="17" FontWeight="Bold" Foreground="#1e293b" />
          <TextBlock Text=" Miner Control" FontSize="17" Foreground="#64748b" />
        </StackPanel>

        <!-- Status pills and quick actions -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="Test RPC" Command="{Binding TestRpcCommand}"
                  Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="10,5"
                  BorderBrush="#e2e8f0" BorderThickness="1" FontSize="11" FontWeight="SemiBold" />
          <Button Content="Test Stratum" Command="{Binding TestStratumCommand}"
                  Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="10,5"
                  BorderBrush="#e2e8f0" BorderThickness="1" FontSize="11" FontWeight="SemiBold" />
          <Border Width="1" Background="#e2e8f0" Height="20" />
          <Border Classes="pill" Background="{Binding BridgePillBg}" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <PathIcon Data="{StaticResource IconBridge}" Width="11" Height="11" Foreground="White" />
              <TextBlock Text="{Binding BridgeStatus}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Border Classes="pill" Background="{Binding MinerPillBg}" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <PathIcon Data="{StaticResource IconMining}" Width="11" Height="11" Foreground="White" />
              <TextBlock Text="{Binding MinerStatus}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Gradient line -->
    <Border Grid.Row="1">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
          <GradientStop Color="#2563eb" Offset="0" />
          <GradientStop Color="#16a34a" Offset="0.5" />
          <GradientStop Color="#f59e0b" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Tabs -->
    <TabControl Grid.Row="2" Background="#f4f6fa" Padding="0" Margin="0,2,0,0">

      <!-- Bridge Tab -->
      <TabItem Header="  Bridge  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="14">

            <!-- Connection Settings Card -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconBridge}" Width="15" Height="15" Foreground="#2563eb" />
                  <TextBlock Classes="sectionTitle" Text="Connection" Foreground="#2563eb" />
                </StackPanel>

                <TextBlock Classes="fieldLabel" Text="Bridge Binary" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding BridgePath}" Watermark="/path/to/lmt-stratum-bridge" CornerRadius="8" Padding="10,8" FontSize="13" />
                  <Button Grid.Column="1" Content="Browse..." Click="BrowseBridgePath_Click"
                          Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,8"
                          BorderBrush="#e2e8f0" BorderThickness="1" />
                </Grid>

                <Grid ColumnDefinitions="*,16,*">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="fieldLabel" Text="Listen Address" />
                    <TextBox Text="{Binding ListenAddress}" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Classes="fieldLabel" Text="gRPC RPC URL" />
                    <TextBox Text="{Binding RpcUrl}" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Mining Settings Card -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconMining}" Width="15" Height="15" Foreground="#d97706" />
                  <TextBlock Classes="sectionTitle" Text="Mining" Foreground="#d97706" />
                </StackPanel>

                <TextBlock Classes="fieldLabel" Text="Pay Address (LMT)" />
                <TextBox Text="{Binding PayAddress}" Watermark="lmt:qz0s..." CornerRadius="8" Padding="10,8" FontSize="13" />

                <Grid ColumnDefinitions="*,16,*">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="fieldLabel" Text="Extra Data (hex, optional)" />
                    <TextBox Text="{Binding ExtraDataHex}" Watermark="" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Classes="fieldLabel" Text="Refresh Interval (ms)" />
                    <TextBox Text="{Binding RefreshMs}" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
                  <CheckBox Content="Allow non-DAA blocks" IsChecked="{Binding AllowNonDaa}" />
                  <CheckBox Content="Auto-restart bridge on crash" IsChecked="{Binding AutoRestartBridge}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,8,*">
              <Button Grid.Column="0" Command="{Binding StartBridgeCommand}" IsEnabled="{Binding !BridgeRunning}"
                      Background="#16a34a" Foreground="White" CornerRadius="8" Padding="0,11" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Data="{StaticResource IconPlay}" Width="13" Height="13" Foreground="White" />
                  <TextBlock Text="Start Bridge" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding StopBridgeCommand}"
                      Background="White" Foreground="#dc2626" CornerRadius="8" Padding="0,11" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#fecaca" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Data="{StaticResource IconStop}" Width="13" Height="13" Foreground="#dc2626" />
                  <TextBlock Text="Stop Bridge" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Miner Tab -->
      <TabItem Header="  Miner  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="14">

            <!-- XMRig Settings -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Data="{StaticResource IconMining}" Width="15" Height="15" Foreground="#16a34a" />
                  <TextBlock Classes="sectionTitle" Text="XMRig Configuration" Foreground="#16a34a" />
                </StackPanel>

                <TextBlock Classes="fieldLabel" Text="XMRig Binary" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding XmrigPath}" Watermark="/path/to/xmrig" CornerRadius="8" Padding="10,8" FontSize="13" />
                  <Button Grid.Column="1" Content="Browse..." Click="BrowseXmrigPath_Click"
                          Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,8"
                          BorderBrush="#e2e8f0" BorderThickness="1" />
                </Grid>

                <Grid ColumnDefinitions="*,16,*">
                  <StackPanel Grid.Column="0">
                    <TextBlock Classes="fieldLabel" Text="Stratum URL" />
                    <TextBox Text="{Binding XmrigUrl}" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Classes="fieldLabel" Text="Extra Arguments" />
                    <TextBox Text="{Binding XmrigExtra}" Watermark="--threads=4 --no-color" CornerRadius="8" Padding="10,8" FontSize="13" />
                  </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
                  <CheckBox Content="Start miner automatically with bridge" IsChecked="{Binding StartMinerWithBridge}" />
                  <CheckBox Content="Auto-restart miner on crash" IsChecked="{Binding AutoRestartMiner}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Live Status (only visible when running) -->
            <Border Classes="card" Background="#f0fdf4" CornerRadius="10" Padding="16" BorderBrush="#bbf7d0" BorderThickness="1"
                    IsVisible="{Binding MinerRunning}">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0">
                  <TextBlock Text="HASHRATE" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                  <TextBlock Text="{Binding Hashrate10S}" Foreground="#166534" FontSize="22" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="24,0">
                  <TextBlock Text="ACCEPTED" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                  <TextBlock Text="{Binding Accepted}" Foreground="#16a34a" FontSize="18" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="24,0">
                  <TextBlock Text="REJECTED" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                  <TextBlock Text="{Binding Rejected}" Foreground="#dc2626" FontSize="18" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="24,0,0,0">
                  <TextBlock Text="UPTIME" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                  <TextBlock Text="{Binding MinerUptime}" Foreground="#1e293b" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,8,*">
              <Button Grid.Column="0" Command="{Binding StartMinerCommand}"
                      Background="#16a34a" Foreground="White" CornerRadius="8" Padding="0,11" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Data="{StaticResource IconPlay}" Width="13" Height="13" Foreground="White" />
                  <TextBlock Text="Start Miner" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding StopMinerCommand}"
                      Background="White" Foreground="#dc2626" CornerRadius="8" Padding="0,11" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" BorderBrush="#fecaca" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Data="{StaticResource IconStop}" Width="13" Height="13" Foreground="#dc2626" />
                  <TextBlock Text="Stop Miner" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Console Tab -->
      <TabItem Header="  Console  ">
        <Grid RowDefinitions="Auto,*" Margin="12">
          <!-- Console toolbar -->
          <Border Grid.Row="0" Background="White" CornerRadius="8,8,0,0" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,1,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource IconTerminal}" Width="14" Height="14" Foreground="#64748b" />
                <TextBlock Text="Process Output" Foreground="#475569" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Column="2" Text="{Binding ConsoleLines.Count, StringFormat='{}{0} lines'}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <ListBox Grid.Row="1" ItemsSource="{Binding ConsoleLines}" Background="#1e1e2e"
                   BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="0,0,8,8"
                   FontFamily="Consolas,Menlo,monospace" FontSize="11" Foreground="#a6e3a1" Padding="8,4" />
        </Grid>
      </TabItem>

      <!-- Metrics Tab -->
      <TabItem Header="  Metrics  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="14">

            <!-- Primary Hashrate Card -->
            <Border Classes="card" Background="White" CornerRadius="12" Padding="20" BorderBrush="#e2e8f0" BorderThickness="1">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconChart}" Width="18" Height="18" Foreground="#16a34a" />
                    <TextBlock Text="Hash Rate" FontSize="16" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{Binding Hashrate10S}" Foreground="#16a34a" FontSize="32" FontWeight="Bold" Margin="0,8,0,4" />
                  <TextBlock Text="10-second average" Foreground="#94a3b8" FontSize="11" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center" Margin="24,0,0,0">
                  <Border Background="#f0fdf4" CornerRadius="8" Padding="14,8">
                    <StackPanel>
                      <TextBlock Text="60s" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                      <TextBlock Text="{Binding Hashrate60S}" Foreground="#166534" FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>
                  <Border Background="#f0fdf4" CornerRadius="8" Padding="14,8">
                    <StackPanel>
                      <TextBlock Text="15m" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                      <TextBlock Text="{Binding Hashrate15M}" Foreground="#166534" FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Shares + Status side by side -->
            <Grid ColumnDefinitions="*,14,*">

              <!-- Shares -->
              <Border Grid.Column="0" Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
                <StackPanel Spacing="12">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconMining}" Width="15" Height="15" Foreground="#2563eb" />
                    <TextBlock Text="Shares" FontSize="14" FontWeight="SemiBold" Foreground="#2563eb" />
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="ACCEPTED" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                      <TextBlock Text="{Binding Accepted}" Foreground="#16a34a" FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="REJECTED" Foreground="#64748b" FontSize="10" FontWeight="Bold" />
                      <TextBlock Text="{Binding Rejected}" Foreground="#dc2626" FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Uptime / Status -->
              <Border Grid.Column="2" Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource IconNode}" Width="15" Height="15" Foreground="#d97706" />
                    <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold" Foreground="#d97706" />
                  </StackPanel>
                  <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bridge" Foreground="#64748b" FontSize="12" Margin="0,3" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BridgeUptime}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="14" Margin="0,3" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Miner" Foreground="#64748b" FontSize="12" Margin="0,3" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MinerUptime}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="14" Margin="0,3" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Latency" Foreground="#64748b" FontSize="12" Margin="0,3" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PoolLatency}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="14" Margin="0,3" />
                  </Grid>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Help Tab -->
      <TabItem Header="  Help  ">
        <ScrollViewer Padding="20">
          <StackPanel Spacing="14">
            <Border Classes="card" Background="White" CornerRadius="10" Padding="20" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Image Source="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png" Width="40" Height="40" />
                  <TextBlock Text="LMT Miner Control Center" FontSize="18" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Foreground="#475569" FontSize="13" TextWrapping="Wrap" LineHeight="22">
                  <Run FontWeight="Bold" Foreground="#1e293b">Quick Start:</Run>
                </TextBlock>
                <TextBlock Foreground="#475569" FontSize="13" TextWrapping="Wrap" LineHeight="22" Margin="8,0,0,0">
                  <Run>1. Set the bridge binary path and your LMT pay address in the Bridge tab.</Run>
                  <LineBreak />
                  <Run>2. Set the XMRig binary path in the Miner tab.</Run>
                  <LineBreak />
                  <Run>3. Click "Start Bridge" to connect to your lmtd node via gRPC.</Run>
                  <LineBreak />
                  <Run>4. Click "Start Miner" (or enable "Start with bridge").</Run>
                  <LineBreak />
                  <Run>5. Monitor hashrate and shares in the Metrics tab.</Run>
                </TextBlock>
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,14,*">
              <Border Grid.Column="0" Classes="card" Background="#eff6ff" CornerRadius="8" Padding="14,12" BorderBrush="#bfdbfe" BorderThickness="1">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#1e40af" FontSize="13" FontWeight="SemiBold">Requirements</TextBlock>
                  <TextBlock Foreground="#1e40af" FontSize="12" TextWrapping="Wrap" LineHeight="20">
                    <Run>lmtd node must be running and synced. Bridge connects via gRPC (default port 26110). XMRig connects to bridge via stratum (default port 3333).</Run>
                  </TextBlock>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Classes="card" Background="#f0fdf4" CornerRadius="8" Padding="14,12" BorderBrush="#bbf7d0" BorderThickness="1">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#166534" FontSize="13" FontWeight="SemiBold">Mining Algorithm</TextBlock>
                  <TextBlock Foreground="#166534" FontSize="12" TextWrapping="Wrap" LineHeight="20">
                    <Run>Lapis Monetae uses RandomX Proof-of-Work. Any CPU can mine -- no GPU or ASIC needed.</Run>
                  </TextBlock>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>

    <!-- Status bar -->
    <Border Grid.Row="3" Background="White" Padding="12,6" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto,12,Auto">
        <TextBlock Text="LMT Miner" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding BridgeStatus, StringFormat='Bridge: {0}'}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding MinerStatus, StringFormat='Miner: {0}'}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" />
      </Grid>
    </Border>

  </Grid>

  <!-- Busy overlay (inside Panel) -->
  <Border IsVisible="{Binding IsBusy}" Background="#40000000" ZIndex="50" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <Border Background="White" CornerRadius="12" Padding="28,20" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 8 24 0 #00000033">
      <TextBlock Text="{Binding BusyText}" Foreground="#1e293b" FontSize="14" FontWeight="SemiBold" />
    </Border>
  </Border>

  <!-- Toast -->
  <Border IsVisible="{Binding ToastVisible}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16,12" ZIndex="200"
          Background="{Binding ActiveToast.Background}" CornerRadius="8" Width="360" BoxShadow="0 4 16 0 #0000001a">
    <Grid ColumnDefinitions="4,Auto,*">
      <Border Grid.Column="0" Background="{Binding ActiveToast.AccentColor}" CornerRadius="8,0,0,8" />
      <TextBlock Grid.Column="1" Text="{Binding ActiveToast.Icon}" Foreground="{Binding ActiveToast.AccentColor}" FontSize="16" VerticalAlignment="Center" Margin="12,10,8,10" />
      <TextBlock Grid.Column="2" Text="{Binding ActiveToast.Text}" Foreground="{Binding ActiveToast.Foreground}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,10,12,10" />
    </Grid>
  </Border>

  </Panel>
</Window>
