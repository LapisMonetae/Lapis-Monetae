<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LmtDesktop.Miner.ViewModels"
        x:Class="LmtDesktop.Miner.MainWindow"
        x:DataType="vm:MinerMainViewModel"
        Title="LMT Miner Control Center"
        Icon="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png"
        Width="860" Height="720" MinWidth="700" MinHeight="620"
        Background="#f4f6fa" WindowStartupLocation="CenterScreen">

  <Design.DataContext><vm:MinerMainViewModel /></Design.DataContext>

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
        </Transitions>
      </Setter>
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Opacity" Value="0.9" />
      <Setter Property="RenderTransform" Value="scale(1.02)" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Transitions">
        <Transitions>
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
      <Setter Property="BoxShadow" Value="0 1 3 0 #0000001a" />
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="BoxShadow" Value="0 4 12 0 #0000001a" />
    </Style>
    <Style Selector="Border.pill">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.3" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Modern TabItem styling -->
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#64748b" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="2,0" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TabItem:pointerover">
      <Setter Property="Foreground" Value="#2563eb" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="#2563eb" />
    </Style>

    <!-- Tab content fade-in -->
    <Style Selector="TabItem:selected > ContentPresenter">
      <Style.Animations>
        <Animation Duration="0:0:0.25" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="8" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#2563eb" />
    </Style>
  </Window.Styles>

  <Panel>
  <Grid RowDefinitions="Auto,2,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="White" Padding="16,8" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,8,Auto">
        <Image Grid.Column="0" Source="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png"
               Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="LMT" FontSize="17" FontWeight="Bold" Foreground="#1e293b" />
          <TextBlock Text=" Miner Control" FontSize="17" Foreground="#64748b" />
        </StackPanel>
        <Border Grid.Column="3" Classes="pill" Background="{Binding BridgePillBg}" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
          <TextBlock Text="{Binding BridgeStatus, StringFormat='Bridge: {0}'}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="5" Classes="pill" Background="{Binding MinerPillBg}" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
          <TextBlock Text="{Binding MinerStatus, StringFormat='Miner: {0}'}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <!-- Gradient line -->
    <Border Grid.Row="1">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
          <GradientStop Color="#2563eb" Offset="0" />
          <GradientStop Color="#16a34a" Offset="0.5" />
          <GradientStop Color="#f59e0b" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Tabs -->
    <TabControl Grid.Row="2" Background="#f4f6fa" Padding="0" Margin="0,2,0,0">

      <!-- Bridge Tab -->
      <TabItem Header="  Bridge  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="14">
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="10">
                <TextBlock Text="Bridge Binary" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding BridgePath}" Watermark="/path/to/lmt-stratum-bridge" CornerRadius="8" Padding="10,8" FontSize="13" />
                  <Button Grid.Column="1" Content="Browse..." Click="BrowseBridgePath_Click"
                          Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,8"
                          BorderBrush="#e2e8f0" BorderThickness="1" />
                </Grid>

                <TextBlock Text="Listen Address" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding ListenAddress}" CornerRadius="8" Padding="10,8" FontSize="13" />

                <TextBlock Text="gRPC RPC URL" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding RpcUrl}" CornerRadius="8" Padding="10,8" FontSize="13" />

                <TextBlock Text="Pay Address (LMT)" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding PayAddress}" Watermark="lmt:qz0s..." CornerRadius="8" Padding="10,8" FontSize="13" />

                <TextBlock Text="Extra Data (hex, optional)" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding ExtraDataHex}" Watermark="" CornerRadius="8" Padding="10,8" FontSize="13" />

                <TextBlock Text="Refresh Interval (ms)" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding RefreshMs}" CornerRadius="8" Padding="10,8" FontSize="13" Width="120" HorizontalAlignment="Left" />

                <StackPanel Spacing="6" Margin="0,4,0,0">
                  <CheckBox Content="Allow non-DAA blocks" IsChecked="{Binding AllowNonDaa}" />
                  <CheckBox Content="Auto-restart bridge on crash" IsChecked="{Binding AutoRestartBridge}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
              <Button Content="Start Bridge" Command="{Binding StartBridgeCommand}" IsEnabled="{Binding !BridgeRunning}"
                      Background="#16a34a" Foreground="White" CornerRadius="8" Padding="20,9" FontWeight="SemiBold" FontSize="14" />
              <Button Content="Stop Bridge" Command="{Binding StopBridgeCommand}"
                      Background="#dc2626" Foreground="White" CornerRadius="8" Padding="20,9" FontWeight="SemiBold" FontSize="14" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Miner Tab -->
      <TabItem Header="  Miner  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="14">
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="10">
                <TextBlock Text="XMRig Binary" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding XmrigPath}" Watermark="/path/to/xmrig" CornerRadius="8" Padding="10,8" FontSize="13" />
                  <Button Grid.Column="1" Content="Browse..." Click="BrowseXmrigPath_Click"
                          Margin="6,0,0,0" Background="#f1f5f9" Foreground="#475569" CornerRadius="8" Padding="12,8"
                          BorderBrush="#e2e8f0" BorderThickness="1" />
                </Grid>

                <TextBlock Text="Stratum URL" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding XmrigUrl}" CornerRadius="8" Padding="10,8" FontSize="13" />

                <TextBlock Text="Extra Arguments" Foreground="#64748b" FontSize="12" FontWeight="SemiBold" />
                <TextBox Text="{Binding XmrigExtra}" Watermark="--threads=4 --no-color" CornerRadius="8" Padding="10,8" FontSize="13" />

                <StackPanel Spacing="6" Margin="0,4,0,0">
                  <CheckBox Content="Start miner automatically with bridge" IsChecked="{Binding StartMinerWithBridge}" />
                  <CheckBox Content="Auto-restart miner on crash" IsChecked="{Binding AutoRestartMiner}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
              <Button Content="Start Miner" Command="{Binding StartMinerCommand}"
                      Background="#16a34a" Foreground="White" CornerRadius="8" Padding="20,9" FontWeight="SemiBold" FontSize="14" />
              <Button Content="Stop Miner" Command="{Binding StopMinerCommand}"
                      Background="#dc2626" Foreground="White" CornerRadius="8" Padding="20,9" FontWeight="SemiBold" FontSize="14" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Console Tab -->
      <TabItem Header="  Console  ">
        <Border Padding="12" Background="#f4f6fa">
          <ListBox ItemsSource="{Binding ConsoleLines}" Background="White"
                   BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8"
                   FontFamily="Consolas,Menlo,monospace" FontSize="11" />
        </Border>
      </TabItem>

      <!-- Metrics Tab -->
      <TabItem Header="  Metrics  ">
        <ScrollViewer Padding="16">
          <StackPanel Spacing="12">
            <!-- Hash Rate -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="5">
                <TextBlock Text="Hash Rate" FontSize="14" FontWeight="SemiBold" Foreground="#16a34a" />
                <Grid ColumnDefinitions="100,*"><TextBlock Text="10s avg" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding Hashrate10S}" Foreground="#1e293b" FontWeight="SemiBold" FontSize="16" /></Grid>
                <Grid ColumnDefinitions="100,*"><TextBlock Text="60s avg" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding Hashrate60S}" Foreground="#1e293b" /></Grid>
                <Grid ColumnDefinitions="100,*"><TextBlock Text="15m avg" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding Hashrate15M}" Foreground="#1e293b" /></Grid>
              </StackPanel>
            </Border>

            <!-- Shares -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="5">
                <TextBlock Text="Shares" FontSize="14" FontWeight="SemiBold" Foreground="#2563eb" />
                <Grid ColumnDefinitions="100,*"><TextBlock Text="Accepted" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding Accepted}" Foreground="#16a34a" FontWeight="SemiBold" /></Grid>
                <Grid ColumnDefinitions="100,*"><TextBlock Text="Rejected" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding Rejected}" Foreground="#dc2626" FontWeight="SemiBold" /></Grid>
              </StackPanel>
            </Border>

            <!-- Uptime / Status -->
            <Border Classes="card" Background="White" CornerRadius="10" Padding="16" BorderBrush="#e2e8f0" BorderThickness="1">
              <StackPanel Spacing="5">
                <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold" Foreground="#d97706" />
                <Grid ColumnDefinitions="100,*"><TextBlock Text="Bridge" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding BridgeUptime}" Foreground="#1e293b" /></Grid>
                <Grid ColumnDefinitions="100,*"><TextBlock Text="Miner" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding MinerUptime}" Foreground="#1e293b" /></Grid>
                <Grid ColumnDefinitions="100,*"><TextBlock Text="Pool Latency" Foreground="#64748b" /><TextBlock Grid.Column="1" Text="{Binding PoolLatency}" Foreground="#1e293b" /></Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Help Tab -->
      <TabItem Header="  Help  ">
        <ScrollViewer Padding="20">
          <Border Classes="card" Background="White" CornerRadius="10" Padding="20" BorderBrush="#e2e8f0" BorderThickness="1">
            <StackPanel Spacing="14">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Image Source="avares://LmtDesktop.Miner/Assets/lmt_icon_64.png" Width="40" Height="40" />
                <TextBlock Text="LMT Miner Control Center" FontSize="18" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center" />
              </StackPanel>

              <TextBlock Foreground="#475569" FontSize="13" TextWrapping="Wrap" LineHeight="22">
                <Run FontWeight="Bold" Foreground="#1e293b">Quick Start:</Run>
              </TextBlock>
              <TextBlock Foreground="#475569" FontSize="13" TextWrapping="Wrap" LineHeight="22" Margin="8,0,0,0">
                <Run>1. Set the bridge binary path and your LMT pay address in the Bridge tab.</Run>
                <LineBreak />
                <Run>2. Set the XMRig binary path in the Miner tab.</Run>
                <LineBreak />
                <Run>3. Click "Start Bridge" to connect to your lmtd node via gRPC.</Run>
                <LineBreak />
                <Run>4. Click "Start Miner" (or enable "Start with bridge").</Run>
                <LineBreak />
                <Run>5. Monitor hashrate and shares in the Metrics tab.</Run>
              </TextBlock>

              <Border Background="#eff6ff" CornerRadius="8" Padding="14,10" BorderBrush="#bfdbfe" BorderThickness="1" Margin="0,4">
                <TextBlock Foreground="#1e40af" FontSize="12" TextWrapping="Wrap" MaxWidth="600">
                  <Run FontWeight="SemiBold">Requirements:</Run>
                  <Run> lmtd node must be running and synced. Bridge connects via gRPC (default port 26110). XMRig connects to bridge via stratum (default port 3333).</Run>
                </TextBlock>
              </Border>

              <Border Background="#f0fdf4" CornerRadius="8" Padding="14,10" BorderBrush="#bbf7d0" BorderThickness="1" Margin="0,4">
                <TextBlock Foreground="#166534" FontSize="12" TextWrapping="Wrap" MaxWidth="600">
                  <Run FontWeight="SemiBold">Mining Algorithm:</Run>
                  <Run> Lapis Monetae uses RandomX Proof-of-Work. Any CPU can mine — no GPU or ASIC needed.</Run>
                </TextBlock>
              </Border>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>

    </TabControl>

    <!-- Status bar -->
    <Border Grid.Row="3" Background="White" Padding="12,5" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,12,Auto">
        <TextBlock Text="LMT Miner" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding BridgeStatus, StringFormat='Bridge: {0}'}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="{Binding MinerStatus, StringFormat='Miner: {0}'}" Foreground="#64748b" FontSize="11" VerticalAlignment="Center" />
      </Grid>
    </Border>

  </Grid>

  <!-- Busy overlay (inside Panel) -->
  <Border IsVisible="{Binding IsBusy}" Background="#40000000" ZIndex="50" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <TextBlock Text="{Binding BusyText}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
  </Border>

  <!-- Toast -->
  <Border IsVisible="{Binding ToastVisible}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16,12" ZIndex="200"
          Background="{Binding ActiveToast.Background}" CornerRadius="8" Width="360" BoxShadow="0 4 16 0 #0000001a">
    <Grid ColumnDefinitions="4,Auto,*">
      <Border Grid.Column="0" Background="{Binding ActiveToast.AccentColor}" CornerRadius="8,0,0,8" />
      <TextBlock Grid.Column="1" Text="{Binding ActiveToast.Icon}" Foreground="{Binding ActiveToast.AccentColor}" FontSize="16" VerticalAlignment="Center" Margin="12,10,8,10" />
      <TextBlock Grid.Column="2" Text="{Binding ActiveToast.Text}" Foreground="{Binding ActiveToast.Foreground}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,10,12,10" />
    </Grid>
  </Border>

  </Panel>
</Window>
